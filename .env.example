# ─── Ambiente ──────────────────────────────────────────────────────────────────
# "production" envia emails de verdade e bloqueia rotas de dev
# "development" imprime magic links no terminal e libera /auth/dev-token
ENV=production

# ─── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://front.estabilizei.com.br
BACKEND_URL=https://backend.estabilizei.com.br

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=troque-por-um-segredo-forte-em-producao
JWT_EXPIRE_DAYS=30
ADMIN_JWT_SECRET=admin-secret-troque-em-producao

# ─── Usuários ──────────────────────────────────────────────────────────────────
BONUS_CADASTRO=3

# ─── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@seudominio.com.br
ADMIN_PASSWORD=senha-forte-do-admin

# ─── SMTP (email de magic link) ────────────────────────────────────────────────
# Para trocar de provedor: edite as 4 linhas abaixo e rode `docker-compose restart`
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@seudominio.com.br
SMTP_PASS=senha-do-email
EMAIL_FROM=noreply@seudominio.com.br

# ─── Mercado Pago (assinaturas mensais) ────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_PLAN_ESSENCIAL=
MP_PLAN_PROFISSIONAL=
MP_PLAN_ESCRITORIO=

# ─── InfinityPay (avulsos + planos anuais) ─────────────────────────────────────
INFINITYPAY_TAG=estabilizei
